.DS_Store

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Local-only user-space bridge and overlay UI (not part of the published hypervisor)
overlay/
src/windows/win_hv/src/cheat.rs
src/windows/win_hv/src/ioctl.rs
